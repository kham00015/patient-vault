# Database — use PostgreSQL in production (HIPAA-eligible with BAA)
DATABASE_URL="file:./dev.db"

# Auth — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# Field-level encryption for PHI at rest (generate with: openssl rand -base64 32)
# Production: use AWS KMS, GCP Cloud KMS, or Azure Key Vault instead
ENCRYPTION_KEY="change-me-to-a-32-byte-base64-key"

# Session timeout in minutes (HIPAA: recommend 15-30 min inactivity)
SESSION_TIMEOUT_MINUTES=30

# OpenAI — server-side only, never expose to client
OPENAI_API_KEY=""

# File storage — local for dev; S3 with SSE-KMS for production
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="./storage"
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_KMS_KEY_ID=

# App
NEXT_PUBLIC_APP_NAME="Patient Vault"
NODE_ENV="development"
