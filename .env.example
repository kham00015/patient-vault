# Database — local dev (Docker): docker compose up postgres -d
# DATABASE_URL="postgresql://patientvault:change_me_in_production@localhost:5432/patientvault"

DATABASE_URL="postgresql://patientvault:change_me_in_production@localhost:5432/patientvault"

# Auth — run: powershell scripts/generate-secrets.ps1
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"
ENCRYPTION_KEY="change-me-to-a-32-byte-base64-key"

SESSION_TIMEOUT_MINUTES=30

# OpenAI — server-side only (use Bedrock/Azure for production BAA)
OPENAI_API_KEY=""

# Storage: local | s3
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="./storage"

# AWS S3 (production — after BAA signed)
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
# AWS_KMS_KEY_ID=""
# AWS_ACCESS_KEY_ID=""      # or use IAM role on instance
# AWS_SECRET_ACCESS_KEY=""

NEXT_PUBLIC_APP_NAME="Patient Vault"
NODE_ENV="development"
